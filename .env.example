# Smart Fundi Backend Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control

# ======================
# SUPABASE (Auto-configured by Softgen)
# ======================
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ======================
# AUTHENTICATION
# ======================
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
# Generate with: openssl rand -base64 32

# ======================
# VODACOM M-PESA API (Tanzania)
# ======================
VODACOM_API_KEY=your_vodacom_api_key
VODACOM_API_SECRET=your_vodacom_api_secret
VODACOM_SHORTCODE=your_business_shortcode
VODACOM_PASSKEY=your_passkey

# ======================
# SUPPORT CONTACTS
# ======================
SUPPORT_PHONE=+255123456789
SUPPORT_EMAIL=support@smartfundi.co.tz

# ======================
# DATABASE (if using external)
# ======================
DATABASE_URL=your_database_url_if_not_using_supabase
